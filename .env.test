# backend service base url, test environment
# rev2 BASE-WEB-ADAPT (feature 013): `pnpm dev` 跑 --mode test,故此檔為 dev 後端來源。
# 由 ApiFox mock 切到 rev2 rust-api(docker 服務名,vite dev proxy `/proxy-default` → 此 target、見 build/config/proxy.ts)。
# 還原 mock 用:VITE_SERVICE_BASE_URL=https://mock.apifox.cn/m1/3109515-0-default
VITE_SERVICE_BASE_URL=http://rust-api:21081

# other backend service base url, test environment
VITE_OTHER_SERVICE_BASE_URL= `{
  "demo": "http://localhost:9528"
}`
